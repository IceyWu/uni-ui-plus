{
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-5000720260410001",
    "@dcloudio/uni-app-harmony": "3.0.0-5000720260410001",
    "@dcloudio/uni-app-plus": "3.0.0-5000720260410001",
    "@dcloudio/uni-components": "3.0.0-5000720260410001",
    "@dcloudio/uni-h5": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-alipay": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-baidu": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-harmony": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-jd": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-lark": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-qq": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-weixin": "3.0.0-5000720260410001",
    "@dcloudio/uni-mp-xhs": "3.0.0-5000720260410001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-5000720260410001",
    "dayjs": "^1.11.20",
    "vue": "^3.4.21",
    "vue-i18n": "^9.1.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-5000720260410001",
    "@dcloudio/uni-cli-shared": "3.0.0-5000720260410001",
    "@dcloudio/uni-stacktracey": "3.0.0-5000720260410001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5000720260410001",
    "@iceywu/utils": "^0.0.54",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@uni-helper/uni-app-types": "1.0.0-alpha.8",
    "@uni-helper/uni-types": "1.0.0-alpha.8",
    "@uni-helper/vite-plugin-uni-components": "0.2.10",
    "@vant/area-data": "^2.1.0",
    "@vant/touch-emulator": "^1.5.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/test-utils": "^2.4.9",
    "@vue/tsconfig": "^0.9.1",
    "axios": "^1.15.2",
    "changelogen": "^0.6.2",
    "cross-env": "^10.1.0",
    "esno": "^4.8.0",
    "fast-glob": "^3.3.3",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "inquirer": "^13.4.2",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "mini-types": "^0.1.7",
    "miniprogram-api-typings": "^5.1.3",
    "sass": "^1.99.0",
    "typescript": "^5.8.3",
    "ultracite": "^7.6.2",
    "vite": "^5.2.8",
    "vitest": "^1.6.0",
    "vue-hooks-pure": "^0.0.35",
    "vue-tsc": "^3.2.7"
  },
  "lint-staged": {
    "*.{js,ts,vue,json,jsonc}": "npx ultracite fix"
  },
  "name": "uni-ui-plus",
  "scripts": {
    "dev:app": "uni -p app",
    "dev:app-android": "uni -p app-android",
    "dev:app-ios": "uni -p app-ios",
    "dev:custom": "uni -p",
    "dev:h5": "uni",
    "dev:h5:ssr": "uni --ssr",
    "dev:mp-alipay": "uni -p mp-alipay",
    "dev:mp-baidu": "uni -p mp-baidu",
    "dev:mp-kuaishou": "uni -p mp-kuaishou",
    "dev:mp-lark": "uni -p mp-lark",
    "dev:mp-qq": "uni -p mp-qq",
    "dev:mp-toutiao": "uni -p mp-toutiao",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:app": "uni build -p app",
    "build:app-android": "uni build -p app-android",
    "build:app-ios": "uni build -p app-ios",
    "build:custom": "uni build -p",
    "build:h5": "uni build",
    "build:h5:ssr": "uni build --ssr",
    "build:mp-alipay": "uni build -p mp-alipay",
    "build:mp-baidu": "uni build -p mp-baidu",
    "build:mp-kuaishou": "uni build -p mp-kuaishou",
    "build:mp-lark": "uni build -p mp-lark",
    "build:mp-qq": "uni build -p mp-qq",
    "build:mp-toutiao": "uni build -p mp-toutiao",
    "build:mp-weixin": "uni build -p mp-weixin",
    "type-check": "vue-tsc --noEmit",
    "docs:serve": "pnpm --filter ./docs serve",
    "dev:docs": "pnpm --filter ./docs dev",
    "build:docs": "pnpm run build:h5 && pnpm --filter ./docs build && esno ./scripts/demoCopy.ts",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "lint:unsafe": "ultracite fix --unsafe",
    "commit": "git-cz",
    "release-major": "changelogen --release --major",
    "release-minor": "changelogen --release --minor",
    "release-patch": "changelogen --release --patch",
    "release-tag": "esno ./scripts/release.ts",
    "build:web-types": "esno ./scripts/build-web-types.ts",
    "build:lib": "esno ./scripts/build-lib.ts",
    "upload:mp-weixin": "uni build -p mp-weixin && minici --platform weixin",
    "upload:mp-alipay": "uni build -p mp-alipay && minici --platform alipay",
    "upload:mp-dingtalk": "uni build -p mp-dingtalk && minici --platform dd",
    "build:qrcode": "esno ./scripts/qrcode.ts",
    "build:changelog": "esno ./scripts/syncChangelog.ts",
    "build:theme-vars": "esno ./scripts/buildThemeVars.ts",
    "test": "vitest",
    "test:h5": "cross-env UNI_PLATFORM=h5 vitest",
    "test:mp-weixin": "cross-env UNI_PLATFORM=mp-weixin vitest",
    "test:all": "pnpm run test:h5 && pnpm run test:mp-weixin",
    "coverage": "vitest run --coverage",
    "coverage:h5": "cross-env UNI_PLATFORM=h5 vitest run --coverage",
    "test:component": "esno ./scripts/test-component.ts",
    "test:workflow": "esno ./scripts/test-workflow.ts"
  },
  "version": "0.0.69",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iceywu/uni-ui-plus.git"
  },
  "config": {
    "commitizen": {
      "path": "git-cz"
    }
  },
  "browserslist": [
    "Android >= 4.4",
    "ios >= 9"
  ],
  "uni-app": {
    "scripts": {
      "mp-dingtalk": {
        "title": "钉钉小程序",
        "env": {
          "UNI_PLATFORM": "mp-alipay"
        },
        "define": {
          "MP-DINGTALK": true
        }
      }
    }
  },
  "files": [
    "lib"
  ],
  "packageManager": "pnpm@10.33.2"
}
