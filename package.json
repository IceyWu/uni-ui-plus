  "lint-staged": {
    "*.{js,ts,vue,json,jsonc}": "npx ultracite fix"
  },
  "name": "uni-ui-plus",
  "scripts": {
    "dev:app": "uni -p app",
    "dev:app-android": "uni -p app-android",
    "dev:app-ios": "uni -p app-ios",
    "dev:custom": "uni -p",
    "dev:h5": "uni",
    "dev:h5:ssr": "uni --ssr",
    "dev:mp-alipay": "uni -p mp-alipay",
    "dev:mp-baidu": "uni -p mp-baidu",
    "dev:mp-kuaishou": "uni -p mp-kuaishou",
    "dev:mp-lark": "uni -p mp-lark",
    "dev:mp-qq": "uni -p mp-qq",
    "dev:mp-toutiao": "uni -p mp-toutiao",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:app": "uni build -p app",
    "build:app-android": "uni build -p app-android",
    "build:app-ios": "uni build -p app-ios",
    "build:custom": "uni build -p",
    "build:h5": "uni build",
    "build:h5:ssr": "uni build --ssr",
    "build:mp-alipay": "uni build -p mp-alipay",
    "build:mp-baidu": "uni build -p mp-baidu",
    "build:mp-kuaishou": "uni build -p mp-kuaishou",
    "build:mp-lark": "uni build -p mp-lark",
    "build:mp-qq": "uni build -p mp-qq",
    "build:mp-toutiao": "uni build -p mp-toutiao",
    "build:mp-weixin": "uni build -p mp-weixin",
    "type-check": "vue-tsc --noEmit",
    "docs:serve": "pnpm --filter ./docs serve",
    "dev:docs": "pnpm --filter ./docs dev",
    "build:docs": "pnpm run build:h5 && pnpm --filter ./docs build && esno ./scripts/demoCopy.ts",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky install",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "lint:unsafe": "ultracite fix --unsafe",
    "commit": "git-cz",
    "release-major": "standard-version --release-as major",
    "release-minor": "standard-version --release-as minor",
    "release-patch": "standard-version --release-as patch",
    "release-tag": "esno ./scripts/release.ts",
    "build:web-types": "esno ./scripts/build-web-types.ts",
    "build:lib": "esno ./scripts/build-lib.ts",
    "upload:mp-weixin": "uni build -p mp-weixin && minici --platform weixin",
    "upload:mp-alipay": "uni build -p mp-alipay && minici --platform alipay",
    "upload:mp-dingtalk": "uni build -p mp-dingtalk && minici --platform dd",
    "build:qrcode": "esno ./scripts/qrcode.ts",
    "build:changelog": "esno ./scripts/syncChangelog.ts",
    "build:theme-vars": "esno ./scripts/buildThemeVars.ts",
    "test": "vitest",
    "test:h5": "cross-env UNI_PLATFORM=h5 vitest",
    "test:mp-weixin": "cross-env UNI_PLATFORM=mp-weixin vitest",
    "test:all": "npm run test:h5 && npm run test:mp-weixin",
    "coverage": "vitest run --coverage",
    "coverage:h5": "cross-env UNI_PLATFORM=h5 vitest run --coverage",
    "test:component": "esno ./scripts/test-component.ts",
    "test:workflow": "esno ./scripts/test-workflow.ts",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "version": "0.0.69",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iceywu/uni-ui-plus.git"
  },
  "config": {
    "commitizen": {
      "path": "git-cz"
    }
  },
  "standard-version": {
    "skip": {
      "tag": true
    }
  },
  "browserslist": [
    "Android >= 4.4",
    "ios >= 9"
  ],
  "uni-app": {
    "scripts": {
      "mp-dingtalk": {
        "title": "钉钉小程序",
        "env": {
          "UNI_PLATFORM": "mp-alipay"
        },
        "define": {
          "MP-DINGTALK": true
        }
      }
    }
  },
  "files": [
    "lib"
  ],
  "packageManager": "pnpm@9.2.0"
}
